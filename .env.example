REACT_APP_MAILCHIMP_URL=
REACT_APP_STRIPE_URL=

# Public display configuration for the Instagram CTA. This is safe to expose.
REACT_APP_IG_USERNAME=gulletstuffer

# Optional frontend override. Defaults to the same-origin Express route.
REACT_APP_IG_FEED_URL=/api/instagram-feed

# Server-side Instagram feed configuration. Do not prefix the token with
# REACT_APP_; REACT_APP_* values are bundled into browser JavaScript.
IG_USER_ID=me
IG_ACCESS_TOKEN=
IG_FEED_LIMIT=10
IG_CACHE_TTL_SECONDS=900
